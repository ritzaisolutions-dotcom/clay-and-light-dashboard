        "sendTo": "={{ $('Validate & Normalize').item.json.email }}",
        "subject": "Erinnerung: Dein Töpferkurs morgen — Clay & Light",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html lang=\"de\">\n<head><meta charset=\"UTF-8\"></head>\n<body style=\"margin:0;padding:0;background:#F0EEE9;font-family:'Georgia',serif;\">\n  <table width=\"100%\" style=\"padding:40px 20px;background:#F0EEE9;\">\n    <tr><td align=\"center\">\n      <table width=\"560\" style=\"background:#fff;border-radius:8px;overflow:hidden;\">\n        <tr><td style=\"background:#6B9A5A;padding:28px 40px;\">\n          <h1 style=\"margin:0;color:#F0EEE9;font-size:22px;font-weight:400;\">Nicht vergessen.</h1>\n        </td></tr>\n        <tr><td style=\"padding:40px;\">\n          <p style=\"color:#1A1714;font-size:16px;\">Hallo {{ $('Validate & Normalize').item.json.name }},</p>\n          <p style=\"color:#9E9189;font-size:15px;line-height:1.7;\">dein Töpferkurs bei Clay &amp; Light beginnt morgen:</p>\n          <p style=\"background:#F0EEE9;padding:16px;border-radius:6px;color:#6B1E2E;font-size:18px;font-weight:700;\">{{ $('Validate & Normalize').item.json.formattedTimeslot }}</p>\n          <p style=\"color:#9E9189;font-size:14px;\">{{ $('Validate & Normalize').item.json.persons }} Person(en) · 110 Minuten · € {{ $('Validate & Normalize').item.json.total_price.toFixed(2) }}</p>\n          <p style=\"color:#9E9189;font-size:13px;line-height:1.7;\">Bitte erscheine pünktlich. Das Material wird 10 Minuten vor Beginn vorbereitet.</p>\n          <p style=\"color:#9E9189;font-size:13px;\">Wir sehen uns bald.<br>Dein Clay &amp; Light Team</p>\n        </td></tr>\n        <tr><td style=\"background:#4A1220;padding:20px 40px;\">\n          <p style=\"margin:0;color:#9E9189;font-size:12px;\">Clay &amp; Light · Wien</p>\n        </td></tr>\n      </table>\n    </td></tr>\n  </table>\n</body>\n</html>",
        "options": {
