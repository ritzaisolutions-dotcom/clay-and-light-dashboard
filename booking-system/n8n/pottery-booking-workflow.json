    {
      "parameters": {
        "sendTo": "hello@clayandlight.at",
        "subject": "=🏺 Neue Töpferbuchung — {{ $('Validate & Normalize').item.json.name }} ({{ $('Validate & Normalize').item.json.persons }} Pers.)",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html lang=\"de\">\n<head><meta charset=\"UTF-8\"></head>\n<body style=\"margin:0;padding:0;background:#F0EEE9;font-family:monospace;\">\n  <table width=\"100%\" style=\"padding:32px;\">\n    <tr><td align=\"center\">\n      <table width=\"560\" style=\"background:#fff;border-radius:6px;border-left:4px solid #6B9A5A;padding:32px;\">\n        <tr><td>\n          <h2 style=\"margin:0 0 24px;color:#6B1E2E;font-size:20px;\">Neue Töpferbuchung</h2>\n          <table width=\"100%\" style=\"border-collapse:collapse;font-size:14px;\">\n            <tr style=\"background:#F0EEE9;\"><td style=\"padding:8px 12px;color:#9E9189;\">Name</td><td style=\"padding:8px 12px;color:#1A1714;\">{{ $('Validate & Normalize').item.json.name }}</td></tr>\n            <tr><td style=\"padding:8px 12px;color:#9E9189;\">E-Mail</td><td style=\"padding:8px 12px;\"><a href=\"mailto:{{ $('Validate & Normalize').item.json.email }}\" style=\"color:#6B9A5A;\">{{ $('Validate & Normalize').item.json.email }}</a></td></tr>\n            <tr style=\"background:#F0EEE9;\"><td style=\"padding:8px 12px;color:#9E9189;\">Telefon</td><td style=\"padding:8px 12px;color:#1A1714;\">{{ $('Validate & Normalize').item.json.phone || '—' }}</td></tr>\n            <tr><td style=\"padding:8px 12px;color:#9E9189;\">Termin</td><td style=\"padding:8px 12px;color:#1A1714;font-weight:bold;\">{{ $('Validate & Normalize').item.json.formattedTimeslot }}</td></tr>\n            <tr style=\"background:#F0EEE9;\"><td style=\"padding:8px 12px;color:#9E9189;\">Personen</td><td style=\"padding:8px 12px;color:#1A1714;\">{{ $('Validate & Normalize').item.json.persons }}</td></tr>\n            <tr><td style=\"padding:8px 12px;color:#9E9189;\">Preis/Person</td><td style=\"padding:8px 12px;color:#1A1714;\">€ {{ $('Validate & Normalize').item.json.price_per_person }}</td></tr>\n            <tr style=\"background:#F0EEE9;\"><td style=\"padding:8px 12px;color:#9E9189;\">Gesamtbetrag</td><td style=\"padding:8px 12px;color:#6B1E2E;font-weight:bold;font-size:16px;\">€ {{ $('Validate & Normalize').item.json.total_price.toFixed(2) }}</td></tr>\n            <tr><td style=\"padding:8px 12px;color:#9E9189;\">Notizen</td><td style=\"padding:8px 12px;color:#1A1714;\">{{ $('Validate & Normalize').item.json.notes || '—' }}</td></tr>\n            <tr style=\"background:#F0EEE9;\"><td style=\"padding:8px 12px;color:#9E9189;\">Marketing</td><td style=\"padding:8px 12px;color:#1A1714;\">{{ $('Validate & Normalize').item.json.marketing_consent ? '✓ Ja' : '✗ Nein' }}</td></tr>\n          </table>\n          <p style=\"margin:24px 0 0;color:#9E9189;font-size:12px;\">Buchungs-ID: {{ $('Insert into Supabase').item.json.id }}</p>\n        </td></tr>\n      </table>\n    </td></tr>\n  </table>\n</body>\n</html>",
        "options": {
          "fromName": "Clay & Light Buchungssystem"
        }
      },
