# ============================================================
# Clay & Light — Environment Variables
# Copy to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# Supabase — get these from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# n8n Webhook URLs — from your n8n instance
NEXT_PUBLIC_N8N_POTTERY_WEBHOOK=https://your-n8n-instance.com/webhook/pottery-booking
NEXT_PUBLIC_N8N_RESERVATION_WEBHOOK=https://your-n8n-instance.com/webhook/table-reservation

# Cookiebot (GDPR)
NEXT_PUBLIC_COOKIEBOT_ID=your-cookiebot-cbid-here

# Optional: Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
